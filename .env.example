# ── 数据库 ──────────────────────────────────────────────
DATABASE_URL=mysql+aiomysql://lgdoc:changeme@lgdoc-mysql:3306/lgdoc

# ── 缓存 ────────────────────────────────────────────────
REDIS_URL=redis://:changeme@lgdoc-redis:6379/0

# ── 对象存储 ─────────────────────────────────────────────
MINIO_ENDPOINT=lgdoc-minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_DOCUMENTS=lgdoc-documents
MINIO_BUCKET_REPORTS=lgdoc-reports
MINIO_USE_SSL=false

# ── 向量数据库 ────────────────────────────────────────────
MILVUS_HOST=lgdoc-milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=doc_vectors

# ── LLM API（见 CLAUDE.md §2.2，Key 不得提交）──────────
LLM_PRIMARY_PROVIDER=qianwen
LLM_API_KEY_PRIMARY=
LLM_API_KEY_BACKUP=
LLM_API_MOCK=false

# ── 安全 ────────────────────────────────────────────────
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# ── 业务参数 ─────────────────────────────────────────────
SEMANTIC_SIMILARITY_THRESHOLD=0.92
MAX_FILE_SIZE_MB=200
MAX_FILE_PAGES=500
AUDIT_LOG_RETENTION_DAYS=180

# ── 应用 ────────────────────────────────────────────────
APP_ENV=dev
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
